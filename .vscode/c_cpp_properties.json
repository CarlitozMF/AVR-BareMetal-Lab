{
    "configurations": [
        {
            "name": "AVR-m328P-C-BM",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/libs/hal_m328p/inc/**",
                "${workspaceFolder}/libs/common",
                "${workspaceFolder}/libs/devices/inc",
                "${workspaceFolder}/projects/**",
                "${workspaceFolder}/tools/avr-gcc/avr/include"
            ],
            "defines": [
                "F_CPU=16000000UL",
                "__AVR_ATmega328P__"
            ],
            "compilerPath": "${workspaceFolder}/tools/avr-gcc/bin/avr-gcc.exe",
            "cStandard": "gnu11",
            "intelliSenseMode": "gcc-x64",
            "compilerArgs": [
                "-mmcu=atmega328p"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "${workspaceFolder}/tools/avr-gcc/avr/include/avr"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}